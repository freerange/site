<!DOCTYPE html>
<html lang="en">
  <head>
    <title>
      URL Shortener - Go Free Range
    </title>
  </head>
  <body>
    <% if flash[:notice].present? %>
      <p><%= flash[:notice] %></p>
    <% end %>

    <% if flash[:alert].present? %>
      <p><%= flash[:alert] %></p>
    <% end %>

    <% if signed_in? %>
      <p><%= button_to 'Sign out', shortener_session_path, method: :delete %></p>
    <% end %>

    <%= yield %>
  </body>
</html>
